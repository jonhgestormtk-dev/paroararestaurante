
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A menu item for the restaurant.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "featured": { "type": "boolean" },
        "promotion": { "type": "boolean" },
        "active": { "type": "boolean" },
        "stock": { "type": "number" },
        "emoji": { "type": "string" }
      },
      "required": ["name", "price", "category", "description"]
    },
    "Category": {
      "title": "Category",
      "description": "A menu category for organization.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "active", "order"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of menu products."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of menu categories."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
