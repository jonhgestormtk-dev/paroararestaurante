
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Item do cardápio do restaurante.",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string", "enum": ["paroara", "egua-na-panela"] },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "promotion": { "type": "boolean" },
        "active": { "type": "boolean" },
        "stock": { "type": "number" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "emoji": { "type": "string" }
      },
      "required": ["name", "price", "category", "restaurantId"]
    },
    "Category": {
      "title": "Category",
      "description": "Categoria do cardápio.",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string", "enum": ["paroara", "egua-na-panela"] },
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "active", "restaurantId"]
    },
    "Order": {
      "title": "Order",
      "description": "Pedido do cliente.",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "customer": { "type": "object" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Configurações globais por restaurante.",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "storeName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "openingHours": { "type": "string" },
        "promoProductId": { "type": "string" }
      }
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Usuário administrativo do sistema.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "operador"] }
      },
      "required": ["username", "password", "role"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Coleção de produtos."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Coleção de categorias."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Coleção de pedidos."
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Configurações."
    },
    "/adminUsers/{userId}": {
      "schema": "AdminUser",
      "description": "Usuários do painel administrativo."
    }
  }
}
