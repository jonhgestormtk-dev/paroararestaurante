
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Item do cardápio do restaurante.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Categoria do cardápio.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "active"]
    },
    "Order": {
      "title": "Order",
      "description": "Pedido do cliente.",
      "type": "object",
      "properties": {
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Coleção de produtos."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Coleção de categorias."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Coleção de pedidos."
    }
  }
}
