
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Item do cardápio do restaurante.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "promotion": { "type": "boolean" },
        "active": { "type": "boolean" },
        "stock": { "type": "number" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "emoji": { "type": "string" }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Categoria do cardápio.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "active"]
    },
    "Order": {
      "title": "Order",
      "description": "Pedido do cliente.",
      "type": "object",
      "properties": {
        "total": { "type": "number" },
        "status": { "type": "string" },
        "customer": { "type": "object" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Configurações globais do restaurante.",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "openingHours": { "type": "string" },
        "promoProductId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Coleção de produtos do cardápio."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Coleção de categorias."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Coleção de pedidos realizados."
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Configurações gerais do sistema."
    }
  }
}
