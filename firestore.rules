
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para Coleções do Cardápio (Produtos e Categorias)
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    // Regras para Pedidos
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Regras para Configurações
    match /settings/{settingsId} {
      allow read, write: if true;
    }

    // Regras para Usuários Administrativos
    // Permite leitura e escrita para o processo de login e bootstrap de usuários
    match /adminUsers/{userId} {
      allow read, write: if true;
    }

    // Regra de segurança padrão para o protótipo
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
