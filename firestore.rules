rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para o Cardápio (Produtos e Categorias)
    // No protótipo, a leitura é pública para os clientes.
    // A escrita está liberada para permitir o gerenciamento via painel admin.
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    // Regras para Pedidos
    // Qualquer cliente pode criar um pedido.
    // No protótipo, a leitura e atualização também estão abertas para o painel admin.
    match /orders/{orderId} {
      allow create, read, update, delete: if true;
    }

    // Regra padrão para qualquer outra coleção (bloqueado por segurança)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}